<?xml version="1.0" encoding="utf-8"?>
<project>

    <!-- ==================== Project Info ==================== -->
    <meta title="Kareshi Project"
          package="com.kareshiproject.game"
          version="0.0.1"
          company="Kareshi Project Team" />

    <!-- ==================== Application ==================== -->
    <app main="Main"
         file="KareshiProject"
         path="export" />

    <!-- ==================== Window ==================== -->
    <window width="1280"
            height="720"
            fps="60"
            background="#000000"
            vsync="true"
            resizable="false" />

    <!-- Mobile: fullscreen + lock orientation -->
    <window fullscreen="true" if="mobile" />
    <window orientation="landscape" if="mobile" />

    <!-- ==================== Icon ==================== -->
    <icon path="arts/icon.png" />

    <!-- ==================== Source ==================== -->
    <source path="source" />

    <!-- ==================== Libraries ==================== -->
    <haxelib name="hxcpp" />
    <haxelib name="lime" />
    <haxelib name="openfl" />
    <haxelib name="flixel" />
    <haxelib name="flixel-ui" />
    <haxelib name="flixel-addons" />

    <!-- Android-only extension -->
    <haxelib name="extension-androidtools" if="android" />

    <!-- ==================== Assets ==================== -->
    <assets path="assets/images" rename="images" />
    <assets path="assets/sounds" rename="sounds" />
    <assets path="assets/music"  rename="music" />
    <assets path="assets/data"   rename="data" />

    <!-- ==================== Build Flags ==================== -->
    <haxeflag name="-debug" if="debug" />
    <define name="FLX_NO_FOCUS_LOST_SCREEN" if="debug" />
    <define name="FLX_NO_MOUSE"    if="mobile" />
    <define name="FLX_NO_KEYBOARD" if="mobile" />

    <!-- ==================== Android Config ==================== -->
    <android package="com.kareshiproject.game"
             versionCode="1"
             versionName="0.0.1"
             minSdkVersion="21"
             targetSdkVersion="33"
             orientation="landscape"
             screenOrientation="landscape"
             appLabel="Kareshi Project"
             apkFileName="KareshiProject-debug.apk"
             allowBackup="false"
             supportsRtl="false"
             if="debug" />

    <android package="com.kareshiproject.game"
             versionCode="1"
             versionName="0.0.1"
             minSdkVersion="21"
             targetSdkVersion="33"
             orientation="landscape"
             screenOrientation="landscape"
             appLabel="Kareshi Project"
             apkFileName="KareshiProject-release.apk"
             allowBackup="false"
             supportsRtl="false"
             unless="debug" />

    <!-- Android permissions -->
    <android permission="android.permission.VIBRATE" />
    <android permission="android.permission.INTERNET" />
    <android permission="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Gradle versions compatíveis com NDK r21e -->
    <config:android gradle-version="7.4.2" gradle-plugin="7.3.1" if="android" />

    <!-- Build tools + compile SDK explícito (evita conflito com android-35 do runner) -->
    <config:android build-tools-version="33.0.2" if="android" />
    <config:android compile-sdk-version="33"     if="android" />

    <!-- Força geração do APK final ao invés de só o projeto Gradle -->
    <config:android assemble-release="true" unless="debug" />
    <config:android assemble-debug="true"   if="debug" />

    <!-- ==================== iOS (future) ==================== -->
    <ios deployment="12" />

</project>